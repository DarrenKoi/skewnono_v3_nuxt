# Nuxt dev server port (default: 3100)
# NUXT_PORT=3100

# Flask backend URL that Nitro's dev proxy forwards /api/* to.
# Phase 1 (home, offline):  http://localhost:5000  (back_dev_home Flask mock)
# Phase 2 (company, local): http://localhost:5000  (real Flask on company network)
# Phase 3 (production):     not needed — Flask serves the built SPA directly
# NUXT_API_TARGET=http://localhost:5000

# API base path the frontend prepends to every request.
# Kept as /api across all phases so frontend code never branches on environment.
# NUXT_PUBLIC_API_BASE=/api
